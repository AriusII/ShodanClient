<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- Used for raw banner text, JSON payloads and other fixed-width content across modules. -->
	<FontFamily x:Key="ShodanMonospaceFont">Cascadia Code, Consolas, JetBrains Mono, monospace</FontFamily>

	<x:Double x:Key="ShodanFontSizeSmall">12</x:Double>
	<x:Double x:Key="ShodanFontSizeNormal">14</x:Double>
	<x:Double x:Key="ShodanFontSizeLarge">18</x:Double>
	<x:Double x:Key="ShodanFontSizeTitle">24</x:Double>

</ResourceDictionary>
