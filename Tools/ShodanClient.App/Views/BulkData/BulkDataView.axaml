<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ShodanClient.App.ViewModels.BulkData"
             xmlns:conv="using:ShodanClient.App.Converters"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:bulkdata="using:ShodanClient.Domain.BulkData"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="ShodanClient.App.Views.BulkData.BulkDataView"
             x:DataType="vm:BulkDataViewModel">
	<UserControl.Resources>
		<conv:NullOrEmptyToVisibilityConverter x:Key="HasContentConverter" />
		<conv:ByteSizeConverter x:Key="ByteSizeConverter" />
	</UserControl.Resources>

	<Grid RowDefinitions="Auto,Auto,*" Margin="16">

		<StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
			<TextBlock Text="{Binding Title}" FontSize="{StaticResource ShodanFontSizeTitle}" FontWeight="Bold"
			           VerticalAlignment="Center" />
			<ui:FAProgressRing IsVisible="{Binding IsBusy}" IsActive="{Binding IsBusy}" IsIndeterminate="True"
			                   Width="18" Height="18" VerticalAlignment="Center" />
			<Button Content="Refresh" Command="{Binding LoadDatasetsCommand}" IsEnabled="{Binding !IsBusy}"
			        VerticalAlignment="Center" />
		</StackPanel>

		<ui:FAInfoBar Grid.Row="1"
		              IsOpen="{Binding RequiresEnterprise}"
		              IsClosable="False"
		              Severity="Warning"
		              Title="Requires an Enterprise plan"
		              Message="Bulk data downloads are only available to accounts on a Shodan Enterprise plan."
		              Margin="0,0,0,12" />

		<Grid Grid.Row="2"
		      ColumnDefinitions="*,2*"
		      IsVisible="{Binding !RequiresEnterprise}">

			<StackPanel Grid.Column="0" Spacing="4" Margin="0,0,12,0">
				<TextBlock Text="Datasets" FontWeight="Bold" Opacity="0.8" />
				<DataGrid ItemsSource="{Binding Datasets}"
				          SelectedItem="{Binding SelectedDataset}"
				          AutoGenerateColumns="False"
				          IsReadOnly="True"
				          GridLinesVisibility="Horizontal"
				          SelectionMode="Single">
					<DataGrid.Columns>
						<DataGridTextColumn x:DataType="bulkdata:Dataset" Header="Name" Binding="{Binding Name}"
						                    Width="*" />
						<DataGridTextColumn x:DataType="bulkdata:Dataset" Header="Scope" Binding="{Binding Scope}"
						                    Width="Auto" />
					</DataGrid.Columns>
				</DataGrid>
				<TextBlock Text="{Binding SelectedDataset.Description}"
				           TextWrapping="Wrap"
				           Opacity="0.7"
				           IsVisible="{Binding SelectedDataset, Converter={StaticResource HasContentConverter}}" />
			</StackPanel>

			<StackPanel Grid.Column="1" Spacing="4">
				<TextBlock Text="Files" FontWeight="Bold" Opacity="0.8" />
				<DataGrid ItemsSource="{Binding Files}"
				          AutoGenerateColumns="False"
				          IsReadOnly="True"
				          GridLinesVisibility="Horizontal"
				          IsVisible="{Binding Files, Converter={StaticResource HasContentConverter}}">
					<DataGrid.Columns>
						<DataGridTextColumn x:DataType="bulkdata:DatasetFile" Header="Name" Binding="{Binding Name}"
						                    Width="*" />
						<DataGridTextColumn x:DataType="bulkdata:DatasetFile" Header="Size"
						                    Binding="{Binding Size, Converter={StaticResource ByteSizeConverter}}"
						                    Width="Auto" />
						<DataGridTextColumn x:DataType="bulkdata:DatasetFile" Header="Timestamp"
						                    Binding="{Binding Timestamp, StringFormat=g}" Width="Auto" />
						<DataGridTemplateColumn Header="" Width="100">
							<DataGridTemplateColumn.CellTemplate>
								<DataTemplate x:DataType="bulkdata:DatasetFile">
									<Button Content="Download"
									        Command="{Binding $parent[DataGrid].((vm:BulkDataViewModel)DataContext).OpenDownloadUrlCommand}"
									        CommandParameter="{Binding}" />
								</DataTemplate>
							</DataGridTemplateColumn.CellTemplate>
						</DataGridTemplateColumn>
					</DataGrid.Columns>
				</DataGrid>
				<TextBlock Text="Select a dataset to see its files."
				           Opacity="0.6"
				           IsVisible="{Binding SelectedDataset, Converter={StaticResource HasContentConverter}, ConverterParameter=Invert}" />
				<TextBlock Text="This dataset has no files."
				           Opacity="0.6"
				           IsVisible="{Binding HasNoFilesForSelectedDataset}" />
			</StackPanel>
		</Grid>
	</Grid>
</UserControl>
