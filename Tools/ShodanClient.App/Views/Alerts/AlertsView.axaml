<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ShodanClient.App.ViewModels.Alerts"
             xmlns:alerts="using:ShodanClient.Domain.Alerts"
             xmlns:notifiers="using:ShodanClient.Domain.Notifiers"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:conv="using:ShodanClient.App.Converters"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
             x:Class="ShodanClient.App.Views.Alerts.AlertsView"
             x:DataType="vm:AlertsViewModel">
	<UserControl.Resources>
		<conv:NullOrEmptyToVisibilityConverter x:Key="HasContentConverter" />
	</UserControl.Resources>

	<Grid ColumnDefinitions="340,*" Margin="16">

		<!-- Left: alert list + create form -->
		<DockPanel Grid.Column="0" Margin="0,0,16,0">

			<Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,8">
				<TextBlock Grid.Column="0" Text="Alerts" FontSize="{StaticResource ShodanFontSizeLarge}"
				           FontWeight="Bold" VerticalAlignment="Center" />
				<ui:FAProgressRing Grid.Column="1" IsVisible="{Binding IsBusy}" IsActive="{Binding IsBusy}"
				                   IsIndeterminate="True" Width="18" Height="18" VerticalAlignment="Center"
				                   Margin="0,0,8,0" />
				<Button Grid.Column="2" Content="Refresh" Command="{Binding LoadCommand}" IsEnabled="{Binding !IsBusy}" />
			</Grid>

			<StackPanel DockPanel.Dock="Bottom" Spacing="{StaticResource ShodanSpacingSmall}" Margin="0,12,0,0">
				<Separator />
				<TextBlock Text="New alert" FontWeight="Bold" />
				<TextBlock
					Text="Free — creating and managing alerts, triggers and notifiers doesn't use Shodan query or scan credits. Each alert's monitored IPs count against your account's IP-monitoring limit (commonly 16 IPs on Membership plans)."
					Opacity="0.6"
					FontSize="{StaticResource ShodanFontSizeSmall}"
					TextWrapping="Wrap" />
				<TextBox PlaceholderText="Name" Text="{Binding NewAlertName}" IsEnabled="{Binding !IsBusy}" />
				<TextBox PlaceholderText="IPs / CIDR ranges (comma or newline separated)"
				         Text="{Binding NewAlertNetworksInput}"
				         AcceptsReturn="True"
				         TextWrapping="Wrap"
				         Height="72"
				         IsEnabled="{Binding !IsBusy}" />
				<TextBox PlaceholderText="Expires in seconds (blank = never)"
				         Text="{Binding NewAlertExpiresSecondsInput}"
				         IsEnabled="{Binding !IsBusy}" />
				<Button Content="Create alert"
				        Command="{Binding CreateCommand}"
				        IsEnabled="{Binding !IsBusy}"
				        HorizontalAlignment="Stretch"
				        HorizontalContentAlignment="Center" />
			</StackPanel>

			<Grid>
				<ListBox ItemsSource="{Binding Alerts}" SelectedItem="{Binding SelectedAlert}">
					<ListBox.ItemTemplate>
						<DataTemplate x:DataType="alerts:Alert">
							<StackPanel Spacing="2" Margin="0,4">
								<TextBlock Text="{Binding Name}" FontWeight="Bold" />
								<TextBlock Text="{Binding Size, StringFormat='{}{0} IPs monitored'}" Opacity="0.7"
								           FontSize="12" />
								<TextBlock Text="{Binding Expires, StringFormat='Expires in {0}s (0 = never)'}"
								           Opacity="0.5"
								           FontSize="12" />
							</StackPanel>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>

				<TextBlock Text="No alerts yet — create one below."
				           Opacity="0.6"
				           HorizontalAlignment="Center"
				           Margin="0,24,0,0"
				           IsVisible="{Binding Alerts, Converter={StaticResource HasContentConverter}, ConverterParameter=Invert}" />
			</Grid>
		</DockPanel>

		<!-- Right: selected alert detail -->
		<TextBlock Grid.Column="1"
		           Text="Select an alert on the left, or create one, to see its details."
		           Opacity="0.6"
		           HorizontalAlignment="Center"
		           VerticalAlignment="Center"
		           IsVisible="{Binding SelectedAlert, Converter={x:Static ObjectConverters.IsNull}}" />

		<ScrollViewer Grid.Column="1"
		              IsVisible="{Binding SelectedAlert, Converter={x:Static ObjectConverters.IsNotNull}}">
			<StackPanel Spacing="16">

				<Grid ColumnDefinitions="Auto,*,Auto,Auto">
					<ui:FAProgressRing Grid.Column="0" IsVisible="{Binding IsBusy}" IsActive="{Binding IsBusy}"
					                   IsIndeterminate="True" Width="18" Height="18" VerticalAlignment="Center"
					                   Margin="0,0,8,0" />
					<TextBlock Grid.Column="1"
					           Text="{Binding SelectedAlert.Name}"
					           FontSize="{StaticResource ShodanFontSizeTitle}"
					           FontWeight="Bold"
					           VerticalAlignment="Center" />
					<Button Grid.Column="2"
					        Content="Stream this alert"
					        Command="{Binding StreamThisAlertCommand}"
					        IsEnabled="{Binding !IsBusy}"
					        Margin="0,0,8,0" />
					<Button Grid.Column="3"
					        Content="Delete alert"
					        Command="{Binding DeleteCommand}"
					        IsEnabled="{Binding !IsBusy}" />
				</Grid>

				<TextBlock
					Text="Click &quot;Delete alert&quot; again to confirm — this permanently removes the alert and its trigger/notifier configuration."
					Foreground="Orange"
					TextWrapping="Wrap"
					IsVisible="{Binding IsDeleteConfirmationPending}" />

				<TextBlock Text="{Binding SelectedAlert.Id}" Opacity="0.5"
				           FontFamily="{StaticResource ShodanMonospaceFont}" FontSize="12" />

				<StackPanel Spacing="6">
					<TextBlock Text="Monitored networks" FontWeight="Bold" />
					<TextBox Text="{Binding UpdateNetworksInput}"
					         AcceptsReturn="True"
					         TextWrapping="Wrap"
					         Height="80"
					         IsEnabled="{Binding !IsBusy}" />
					<Button Content="Save networks" Command="{Binding UpdateNetworksCommand}"
					        IsEnabled="{Binding !IsBusy}"
					        HorizontalAlignment="Left" />
				</StackPanel>

				<Separator />

				<StackPanel Spacing="6">
					<TextBlock Text="Triggers" FontWeight="Bold" />
					<ItemsControl ItemsSource="{Binding TriggerToggles}">
						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="vm:TriggerToggleViewModel">
								<Border Padding="8" Margin="0,4" CornerRadius="6" Background="#11FFFFFF">
									<StackPanel Spacing="4">
										<Grid ColumnDefinitions="*,Auto,Auto">
											<StackPanel Grid.Column="0">
												<TextBlock Text="{Binding Name}" FontWeight="Bold" />
												<TextBlock Text="{Binding Description}"
												           Opacity="0.6"
												           FontSize="12"
												           TextWrapping="Wrap"
												           IsVisible="{Binding Description, Converter={x:Static ObjectConverters.IsNotNull}}" />
											</StackPanel>
											<Button Grid.Column="1"
											        Content="Disable"
											        Command="{Binding ToggleCommand}"
											        IsVisible="{Binding IsEnabled}"
											        IsEnabled="{Binding $parent[ItemsControl].((vm:AlertsViewModel)DataContext).IsBusy, Converter={x:Static BoolConverters.Not}}" />
											<Button Grid.Column="2"
											        Content="Enable"
											        Command="{Binding ToggleCommand}"
											        IsVisible="{Binding !IsEnabled}"
											        IsEnabled="{Binding $parent[ItemsControl].((vm:AlertsViewModel)DataContext).IsBusy, Converter={x:Static BoolConverters.Not}}" />
										</Grid>

										<Grid ColumnDefinitions="*,Auto,Auto">
											<TextBox Grid.Column="0"
											         PlaceholderText="Whitelist a service, e.g. 1.2.3.4:443"
											         Text="{Binding ServiceInput}"
											         IsEnabled="{Binding $parent[ItemsControl].((vm:AlertsViewModel)DataContext).IsBusy, Converter={x:Static BoolConverters.Not}}" />
											<Button Grid.Column="1"
											        Content="Ignore"
											        Margin="4,0,0,0"
											        Command="{Binding IgnoreServiceCommand}"
											        IsEnabled="{Binding $parent[ItemsControl].((vm:AlertsViewModel)DataContext).IsBusy, Converter={x:Static BoolConverters.Not}}" />
											<Button Grid.Column="2"
											        Content="Unignore"
											        Margin="4,0,0,0"
											        Command="{Binding UnignoreServiceCommand}"
											        IsEnabled="{Binding $parent[ItemsControl].((vm:AlertsViewModel)DataContext).IsBusy, Converter={x:Static BoolConverters.Not}}" />
										</Grid>
									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>

				<Separator />

				<StackPanel Spacing="6">
					<Grid ColumnDefinitions="*,Auto">
						<TextBlock Grid.Column="0" Text="Notifiers" FontWeight="Bold" VerticalAlignment="Center" />
						<Button Grid.Column="1" Content="Attach a notifier"
						        Command="{Binding OpenNotifierPickerCommand}"
						        IsEnabled="{Binding !IsBusy}" />
					</Grid>

					<ItemsControl ItemsSource="{Binding SelectedAlert.Notifiers}">
						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="alerts:AlertNotifierRef">
								<Grid ColumnDefinitions="*,Auto" Margin="0,2">
									<TextBlock Grid.Column="0" Text="{Binding Provider}" VerticalAlignment="Center" />
									<Button Grid.Column="1"
									        Content="Detach"
									        Command="{Binding $parent[ItemsControl].((vm:AlertsViewModel)DataContext).DetachNotifierCommand}"
									        CommandParameter="{Binding}"
									        IsEnabled="{Binding $parent[ItemsControl].((vm:AlertsViewModel)DataContext).IsBusy, Converter={x:Static BoolConverters.Not}}" />
								</Grid>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

					<StackPanel Spacing="8" IsVisible="{Binding IsNotifierPickerOpen}">
						<StackPanel Orientation="Horizontal"
						            Spacing="8"
						            IsVisible="{Binding AttachableNotifiers, Converter={StaticResource HasContentConverter}}">
							<ComboBox ItemsSource="{Binding AttachableNotifiers}"
							          SelectedItem="{Binding NotifierToAttach}"
							          PlaceholderText="Choose a notifier"
							          IsEnabled="{Binding !IsBusy}">
								<ComboBox.ItemTemplate>
									<DataTemplate x:DataType="notifiers:Notifier">
										<TextBlock Text="{Binding Provider}" />
									</DataTemplate>
								</ComboBox.ItemTemplate>
							</ComboBox>
							<Button Content="Attach" Command="{Binding AttachNotifierCommand}"
							        IsEnabled="{Binding !IsBusy}" />
							<Button Content="Cancel" Command="{Binding CancelNotifierPickerCommand}"
							        IsEnabled="{Binding !IsBusy}" />
						</StackPanel>

						<StackPanel Orientation="Horizontal"
						            Spacing="8"
						            IsVisible="{Binding AttachableNotifiers, Converter={StaticResource HasContentConverter}, ConverterParameter=Invert}">
							<TextBlock Text="No notifiers configured yet — create one in the Notifiers module first."
							           Opacity="0.6"
							           VerticalAlignment="Center" />
							<Button Content="Cancel" Command="{Binding CancelNotifierPickerCommand}"
							        IsEnabled="{Binding !IsBusy}" />
						</StackPanel>
					</StackPanel>
				</StackPanel>

			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>
